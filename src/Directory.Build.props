<Project>
  <PropertyGroup>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>disable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!--
      When upgrading the .NET SDK, new analyzer rules may activate and become
      build errors via TreatWarningsAsErrors. Add severity overrides for those
      diagnostics in /.editorconfig (see the "Analyzer severity map" section)
      rather than using NoWarn per-project or disabling rules globally.
      For a full ruleset upgrade, set <AnalysisLevel>X.Y-Recommended</AnalysisLevel>
      here, fix or suppress the new diagnostics, then remove this comment.
    -->
  </PropertyGroup>

  <PropertyGroup>
    <Authors>en-gen and contributors</Authors>
    <PackageProjectUrl>https://github.com/en-gen/OhData</PackageProjectUrl>
    <RepositoryUrl>https://github.com/en-gen/OhData</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageTags>odata;odata4;aspnetcore;rest;api</PackageTags>
    <PackageReleaseNotes>https://github.com/en-gen/OhData/blob/main/CHANGELOG.md</PackageReleaseNotes>
    <!-- Symbols: produces .snupkg for debugger step-in support -->
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <!-- Source Link: resolves debugger source to the exact GitHub commit -->
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
  </PropertyGroup>

  <ItemGroup>
    <None Include="$(MSBuildThisFileDirectory)..\README.md" Pack="true" PackagePath="/" Visible="false" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="GitVersion.MsBuild" Version="6.7.0" PrivateAssets="All" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.*" PrivateAssets="All" />
  </ItemGroup>
</Project>
