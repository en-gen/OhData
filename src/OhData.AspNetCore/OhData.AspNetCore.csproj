<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<PackageId>OhData.AspNetCore</PackageId>
		<Description>Convention-based OData 4.0 server for ASP.NET Core minimal APIs.</Description>
		<!-- AD0001: RouteHandlerAnalyzer NullReferenceException — pre-existing analyzer bug, not our code -->
		<NoWarn>$(NoWarn);AD0001</NoWarn>
	</PropertyGroup>

	<ItemGroup>
		<FrameworkReference Include="Microsoft.AspNetCore.App" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.OData" Version="[9.4.*, 10)" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\OhData.Abstractions\OhData.Abstractions.csproj" />
		<ProjectReference Include="..\OhData.Abstractions.AspNetCore.OData\OhData.Abstractions.AspNetCore.OData.csproj" />
	</ItemGroup>

</Project>
