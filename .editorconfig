root = true

[*]
indent_style              = space
indent_size               = 4
end_of_line               = lf
trim_trailing_whitespace  = true
insert_final_newline      = true
charset                   = utf-8

[*.cs]
# Namespace style — file-scoped required
csharp_style_namespace_declarations = file_scoped:warning

# Braces: allow omission for genuine single-liners; require when multi-line
csharp_prefer_braces = when_multiline:warning

# var policy — no var for built-in types; suggestion elsewhere
csharp_style_var_for_built_in_types  = false:warning
csharp_style_var_when_type_is_apparent = false:suggestion
csharp_style_var_elsewhere           = false:suggestion

# Target-typed new() preferred
csharp_style_implicit_object_creation_when_type_is_apparent = true:suggestion

# Null checks — is null / is not null
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:warning

# Allman braces (matches codebase)
csharp_new_line_before_open_brace = all

# Expression-bodied members
csharp_style_expression_bodied_methods    = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_accessors  = true:suggestion

# No this. qualifier
dotnet_style_qualification_for_field    = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method   = false:suggestion
dotnet_style_qualification_for_event    = false:suggestion

# ── Analyzer severity map ────────────────────────────────────────────────────
#
# TreatWarningsAsErrors=true promotes every warning to a build error. The rules
# below are the intentional exceptions — diagnostics that are advisory in this
# codebase but shouldn't break the build. Adjust here rather than adding NoWarn
# per-project, so the policy is visible in one place.
#
# Production code (.cs in non-test/bench projects) uses the strict defaults
# from TreatWarningsAsErrors + AnalysisLevel=latest-Recommended.

# Test and benchmark projects: relax rules that are noise in test code
[src/**/*Tests*/**/*.cs]
# CS1591: missing XML doc comment — tests don't expose a public API
dotnet_diagnostic.CS1591.severity = none
# CA2000: dispose objects before losing scope — test HTTP content is
# disposed by the framework on request teardown; flagging it is noise
dotnet_diagnostic.CA2000.severity = suggestion
# CA1707: identifiers should not contain underscores — test method names use_underscores
dotnet_diagnostic.CA1707.severity = none

[src/**/*Bench*/**/*.cs, src/**/*TestBench*/**/*.cs]
dotnet_diagnostic.CS1591.severity = none
dotnet_diagnostic.CA2000.severity = suggestion

[*.{yml,yaml}]
indent_size = 2

[*.json]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
