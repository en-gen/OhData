{
  "metadata": [
    {
      "src": [
        {
          "src": "../src",
          "files": [
            "OhData.AspNetCore/OhData.AspNetCore.csproj",
            "OhData.Client/OhData.Client.csproj"
          ]
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net10.0"
      },
      "outputFormat": "mref",
      "memberLayout": "separatePages",
      "enumSortOrder": "declaringOrder"
    }
  ],
  "build": {
    "content": [
      {
        "files": [ "*.md", "toc.yml" ],
        "exclude": [ "_site/**", "api/**" ]
      },
      {
        "src": "../docs",
        "files": [ "**/*.md" ],
        "exclude": [ "design/**", "superpowers/**" ]
      },
      {
        "files": [ "api/**.yml", "api/index.md" ]
      }
    ],
    "resource": [
      {
        "src": "../assets",
        "files": [ "icon.svg", "icon-64.png", "icon-512.png", "social-card.png" ]
      }
    ],
    "output": "_site",
    "template": [ "default", "modern" ],
    "globalMetadata": {
      "_appName": "OhData",
      "_appTitle": "OhData",
      "_appLogoPath": "icon.svg",
      "_appFaviconPath": "icon-64.png",
      "_enableSearch": true,
      "_disableContribution": true,
      "pdf": false
    },
    "postProcessors": [ "ExtractSearchIndex" ],
    "keepFileLink": false,
    "disableGitFeatures": false
  }
}
